generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url теперь берется из prisma.config.ts
}

// Пример модели
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}