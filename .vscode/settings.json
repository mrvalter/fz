{
    // Отключает автоматическое определение отступов из открываемых файлов.
    // Это позволяет принудительно использовать настройки из этого файла.
    "editor.detectIndentation": false,
    
    // Размер отступа в пробелах. Чаще всего используется 2 или 4.
    "editor.tabSize": 4,
    
    // Тип отступа: true - пробелы, false - табуляции.
    // Для современных проектов рекомендуется использовать true (пробелы).
    "editor.insertSpaces": true,

    // 1. ВКЛЮЧАЕМ АВТОФОРМАТИРОВАНИЕ ПРИ СОХРАНЕНИИ
    "editor.formatOnSave": true,        
}